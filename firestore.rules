rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function admin() {
      return signedIn() && request.auth.token.email == "jivy26@gmail.com";
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || admin());
      allow write: if admin();
    }

    match /conspiracies/{docId} {
      allow read: if true;
      allow write: if admin();
    }

    match /evidences/{docId} {
      allow read: if true;
      allow write: if admin();
    }

    match /connections/{docId} {
      allow read: if true;
      allow write: if admin();
    }

    match /search_runs/{docId} {
      allow read, write: if admin();
    }

    match /analysis_jobs/{docId} {
      allow read, write: if admin();
    }

    match /discovery_queries/{docId} {
      allow read, write: if admin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
